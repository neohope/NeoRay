# NeoRay 配置文件
# 复制此文件为 config.toml 并填入你的配置

[app]
name = "neoray"
version = "0.1.0"
env = "development"

[server]
host = "127.0.0.1"
port = 8080

[logger]
level = "info"
format = "json"
output = ["stdout", "file"]

# 日志文件配置
[logger.file]
# 日志路径
path = "logs/neoray.log"
# 单个日志文件最大大小 (MB)
max_size = 100
# 保留的历史文件数量
max_backups = 30
# 保留的历史天数
max_age = 28
# 是否压缩历史日志
compress = true
# 是否按日期拆分日志
rotate_daily = true

[database]
driver = "sqlite"

[llm]
default_provider = "anthropic"

# Anthropic API 配置示例
[llm.anthropic]
api_format = "anthropic"
api_key = ""
api_url = "https://api.anthropic.com"
model = "claude-3-sonnet-20240229"
max_tokens = 4096
temperature = 0.7
timeout = "120s"

# OpenAI 兼容的 API 配置示例
[llm.openai]
api_format = "openai"
api_key = ""
api_url = "https://api.openai.com/v1"
model = "gpt-4"
max_tokens = 4096
temperature = 0.7
timeout = "120s"

# 小米/其他 OpenAI 兼容 API 示例
[llm.xiaomimimo]
api_format = "openai"
api_key = ""
api_url = "https://token-plan-cn.xiaomimimo.com/v1"
model = "mimo-v2.5-pro"
max_tokens = 4096
temperature = 0.7
timeout = "120s"

[tools]
workspace.enabled = true
shell.enabled = true
web.enabled = true

[channels]
websocket.enabled = true
feishu.enabled = false
