# NeoRay 配置示例

[app]
name = "NeoRay AI Assistant"
version = "0.1.0"
env = "development"

[server]
host = "127.0.0.1"
port = 8080
read_timeout = 60
write_timeout = 60
idle_timeout = 120

[llm]
default_provider = "anthropic"

# 主提供商配置 (Anthropic)
[llm.providers.anthropic]
api_key = "sk-ant-..."
api_url = "https://api.anthropic.com"
model = "claude-3-opus-20240229"
max_tokens = 4096
temperature = 0.7
timeout = 60
reasoning_effort = "medium"  # 可选: low, medium, high, adaptive, none
prompt_cache_enabled = true  # 启用提示缓存

# 备用提供商 1 (OpenAI)
[llm.providers.openai]
api_key = "sk-..."
api_url = "https://api.openai.com/v1"
model = "gpt-4"
max_tokens = 4096
temperature = 0.7
timeout = 60

# 备用提供商 2 (DeepSeek)
[llm.providers.deepseek]
api_key = "sk-..."
api_url = "https://api.deepseek.com/v1"
model = "deepseek-chat"
max_tokens = 4096
temperature = 0.7
timeout = 60

# Fallback 模型配置 - 当主提供商失败时会依次尝试这些
[[llm.fallback_models]]
model = "gpt-4"
provider = "openai"
max_tokens = 4096
temperature = 0.7
reasoning_effort = "none"

[[llm.fallback_models]]
model = "deepseek-chat"
provider = "deepseek"
max_tokens = 4096
temperature = 0.7

[memory]
workspace = "~/.neoray/workspace"
git_enabled = true
dream_interval = "2h"
session_ttl_minutes = 1440
max_history_entries = 1000

[session]
[session.storage]
type = "file"
max_sessions = 100
max_messages_per_session = 1000

[session.context]
max_tokens = 8192
compression_strategy = "truncate"
auto_summarize = true
summarize_threshold = 0.8

[tools]
[tools.workspace]
enabled = true
allowed_paths = ["~/.neoray/workspace"]
read_only = false

[tools.filesystem]
enabled = true
max_file_size = 10485760
allowed_extensions = [".txt", ".md", ".json", ".yaml", ".yml", ".toml", ".go", ".py", ".js", ".ts", ".html", ".css"]
blocked_extensions = [".exe", ".dll", ".so", ".dylib", ".bin"]

[tools.shell]
enabled = true
timeout = 30
allowed_commands = ["ls", "cd", "pwd", "cat", "echo", "git", "grep", "find"]
blocked_commands = ["rm -rf", "mkfs", "dd"]
working_dir = "~/.neoray/workspace"

[tools.web]
enabled = true
timeout = 30
max_content_length = 10485760
blocked_domains = ["malicious.example.com"]

[tools.cron]
enabled = true
max_jobs = 10

[skills]
enabled = true
builtin_skills_dir = "skills"
disabled_skills = []
auto_load_always = true

[channels]
[channels.websocket]
enabled = true
path = "/ws"
ping_interval = 30
write_wait = 10
pong_wait = 60
max_message_size = 10485760

[channels.feishu]
enabled = false
app_id = "cli_..."
app_secret = "..."
verification_token = "..."
encrypt_key = "..."
domain = "feishu.cn"
group_policy = "mention"
reply_to_message = true
topic_isolation = true
react_emoji = "THINKING"
done_emoji = "OK"
tool_hint_prefix = "🔧"
streaming = true

[security]
[security.auth]
enabled = true
# IMPORTANT: Generate a strong random secret before deploying!
# Example: openssl rand -hex 32
secret_key = ""
jwt_expiry = 86400

[security.rate_limit]
enabled = false
requests_per_minute = 60
burst = 10

[security.upload]
enabled = true
max_size = 10485760
allowed_types = ["text/plain", "application/json", "text/markdown"]
temp_dir = "~/.neoray/tmp"

[logger]
level = "debug"
format = "text"
output = ["stdout", "file"]

[logger.file]
path = "~/.neoray/logs/neoray.log"
max_size = 100
max_backups = 5
max_age = 30
compress = true
rotate_daily = true

[database]
driver = "sqlite"

[database.sqlite]
path = "~/.neoray/data/neoray.db"

[database.postgres]
host = "localhost"
port = 5432
user = "neoray"
# IMPORTANT: Change this before deploying!
password = ""
dbname = "neoray"
sslmode = "disable"

[web]
enabled = true
static_dir = "webui/dist"
index_path = "webui/dist/index.html"
